; tailwind-preset-mantine@3.1.0 declares its @mantine/core peer range as
; "^7 || ^7 || ^9" — a typo upstream that excludes Mantine 8 even though
; the package works fine with it. Without this flag, `npm ci` on Vercel
; (and any clean CI) fails with ERESOLVE. Mirrors the local global setting.
legacy-peer-deps=true
