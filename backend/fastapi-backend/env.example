# eClinic Backend - Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME="eClinic Backend"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ENCRYPTION_KEY=generate-using-python-cryptography-fernet-generatekey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list of allowed origins)
# Common local development ports: 3000 (React), 5173 (Vite), 8080 (Vue), 4200 (Angular)
# For production, include your server IP/domain: http://139.59.25.254,https://yourdomain.com
# IMPORTANT: Include both HTTP and HTTPS if you use both, and include the exact origin (with/without port, with/without trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080,http://139.59.25.254

# Database
# For external tools (pgAdmin, local scripts): use localhost:5434
# For backend service (Docker): uses postgres:5432 via Docker network (handled by docker-compose.yml)
DATABASE_URL=postgresql://eclinic_user:Eclinic0789@localhost:5434/eclinic_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMS
SMS_ENABLED=false

# WhatsApp
WHATSAPP_ENABLED=false
